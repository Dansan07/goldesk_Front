<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:elevation="24dp"
    app:cardCornerRadius="20dp"
    app:cardPreventCornerOverlap="true"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header con gradiente futbolero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Nombre del Equipo -->
            <TextView
                android:id="@+id/nombreEquipoEstats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Equipo"
                android:textSize="12sp"
                android:textColor="#B3FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <!-- Línea decorativa -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="#FFFFFF"
                android:alpha="0.7"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Nombre del Jugador -->
                <TextView
                    android:id="@+id/dorsalJugadorEstats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dorsal"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_margin="8dp"/>

                <!-- Nombre del Jugador -->
                <TextView
                    android:id="@+id/nombreJugadorEstats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del Jugador"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_margin="8dp"/>

            </LinearLayout>



        </LinearLayout>

        <!-- Contenedor de estadísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#00F8F9FA">

            <!-- Goles -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvGolesParticipante"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="⚽ Goles"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnSumarGol"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_plus"
                        android:backgroundTint="#4CAF50"
                        android:layout_marginStart="12dp"
                        android:contentDescription="Sumar gol"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Amarilla -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvAmarillasParticipante"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="🟨 T. Amarilla"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnSumarAmarilla"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_plus"
                        android:backgroundTint="#4CAF50"
                        android:layout_marginStart="12dp"
                        android:contentDescription="Sumar amarilla"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Azul -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvAzulesParticipante"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="🟦 T. Azul"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnSumarAzul"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_plus"
                        android:backgroundTint="#4CAF50"
                        android:layout_marginStart="12dp"
                        android:contentDescription="Sumar azul"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tarjeta Roja -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvRojasParticipante"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="🟥 T. Roja"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center"/>

                    <ImageButton
                        android:id="@+id/btnSumarRoja"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_plus"
                        android:backgroundTint="#4CAF50"
                        android:layout_marginStart="12dp"
                        android:contentDescription="Sumar roja"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_cancelar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button"
                app:backgroundTint="@color/soccer_green"
                android:textColor="@color/white"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
