<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white_surface"
    android:layout_gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:weightSum="3">

        <!-- Icono indicador (opcional según tipo) -->
        <View
            android:id="@+id/viewIndicadorGoles"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="@color/soccer_green"
            android:layout_marginEnd="16dp" />

        <!-- Contenedor de texto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="3">

            <!-- Texto principal -->
            <TextView
                android:id="@+id/tvTiempoEventoGoles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gol al minuto 45'"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="2dp"/>

            <!-- Texto secundario (opcional) -->
            <TextView
                android:id="@+id/tvPeridoPartidoGoles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Primera parte"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:visibility="visible"/>

        </LinearLayout>

        <!-- Botón eliminar -->
        <ImageButton
            android:id="@+id/btnEliminarGoles"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_minus"
            android:layout_marginStart="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/error_red"
            android:contentDescription="@string/eliminar"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>