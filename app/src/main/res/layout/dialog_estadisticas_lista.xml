<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardPreventCornerOverlap="true"
    app:cardBackgroundColor="@color/white_surface"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header con gradiente futbolero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Nombre del Equipo -->
            <TextView
                android:id="@+id/tvEquipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Equipo"
                android:textSize="12sp"
                android:textColor="#B3FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <!-- Nombre del Jugador -->
            <TextView
                android:id="@+id/tvJugador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Jugador"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <!-- Línea decorativa -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="#FFFFFF"
                android:alpha="0.7"/>

        </LinearLayout>

        <!-- Contenedor de estadísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/white_surface">

            <!-- Título de la sección -->
            <TextView
                android:id="@+id/tvTituloSeccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚽ Goles Registrados"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <!-- RecyclerView para la lista -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEstadisticas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false" />

            <!-- Mensaje cuando está vacío -->
            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_hay_registros"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="32dp" />

            <!-- Botón Cerrar -->
            <Button
                android:id="@+id/btnCerrar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cerrar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/soccer_green"
                android:textColor="@color/soccer_green"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>