<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white_surface"
    android:orientation="vertical">

    <!-- Header del Dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/soccer_green"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gestionar_torneos"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/gestionar_torneos_aux"
                android:textColor="@color/white_translucent_70"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCerrarGestionTorneos"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_clear"
            app:tint="@color/white"
            android:contentDescription="@string/btn_cancelar" />
    </LinearLayout>

    <!-- Lista de Torneos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewGestionTorneos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/layoutEmptyGestionTorneos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_trophy"
            app:tint="@color/text_secondary"
            android:alpha="0.3"
            android:contentDescription="@string/sin_torneos" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sin_torneos"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>