<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/soccer_green"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_traspasos"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/activity_traspasos_aux"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.7"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filtros de Estado -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleEstadoGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:singleSelection="true"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPendientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Goldesk.RoleButton"
            android:text="@string/pendientes">
        </com.google.android.material.button.MaterialButton>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAprobados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Goldesk.RoleButton"
            android:text="@string/aprobados">
        </com.google.android.material.button.MaterialButton>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRechazados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Goldesk.RoleButton"
            android:text="@string/rechazados">
        </com.google.android.material.button.MaterialButton>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Contador de Traspasos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textViewContador"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/total_traspasos"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilAccessCode"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/soccer_green"
        app:boxStrokeColor="@color/soccer_green"
        app:hintTextColor="@color/soccer_green"
        android:hint="@string/buscar_traspasos">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="40dp"
            android:inputType="text"
            android:textSize="13sp"
            android:textColor="@color/text_primary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Lista de Traspasos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTraspasos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Estado Vacío -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_team_empty"
            android:alpha="0.3"
            android:contentDescription="@string/sin_traspasos" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sin_traspasos"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sin_traspasos_pendientes"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:alpha="0.7" />
    </LinearLayout>

</LinearLayout>