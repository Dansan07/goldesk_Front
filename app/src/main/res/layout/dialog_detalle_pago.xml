<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header verde -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/soccer_green"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tipo de concepto: "Tarjeta Amarilla" o "Inscripción" -->
            <TextView
                android:id="@+id/tvTipoConceptoPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarjeta Amarilla"
                android:textColor="@color/white_translucent_70"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <!-- Nombre del jugador -->
            <TextView
                android:id="@+id/tvNombreJugadorPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cristiano Ronaldo"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Nombre del equipo -->
            <TextView
                android:id="@+id/tvEquipoJugadorPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Real Madrid FC"
                android:textColor="@color/white_translucent_70"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Resumen de deuda -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resumen_deuda"
                        android:textColor="@color/soccer_green"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Fila: Monto total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/monto_total"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvMontoTotalPago"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$150.000"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Fila: Ya pagado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ya_pagado"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvYaPagadoPago"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$50.000"
                            android:textColor="@color/clasificacion_directa"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="8dp" />

                    <!-- Fila: Saldo pendiente (destacado) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/saldo_pendiente"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSaldoPendientePago"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$100.000"
                            android:textColor="@color/zona_eliminacion"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Historial de abonos -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/historial_abonos"
                            android:textColor="@color/soccer_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCantidadAbonos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 abonos"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Lista de abonos -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewAbonos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="200dp"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:visibility="gone"/>
                    <LinearLayout
                        android:id="@+id/layoutEmptyContabilidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp">

                        <ImageView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/ic_money"
                            app:tint="@color/text_secondary"
                            android:alpha="0.3"
                            android:contentDescription="@string/sin_registros" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/sin_registros"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Estado vacío del historial -->
                    <TextView
                        android:id="@+id/tvSinAbonos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_abonos_registrados"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Registrar nuevo pago -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRegistrarPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/highlight_verde_sutil">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/registrar_nuevo_pago"
                        android:textColor="@color/highlight_verde_sutil_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_pago_parcial"
                        android:textColor="@color/highlight_verde_sutil_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/soccer_green"
                        app:hintTextColor="@color/soccer_green"
                        app:startIconDrawable="@drawable/ic_money"
                        app:startIconTint="@color/soccer_green"
                        android:hint="@string/hint_monto"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextMontoPago"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary"
                            android:paddingStart="40dp"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnRegistrarPago"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/btn_primary"
                        android:text="@string/registrar_pago"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Cerrar -->
            <Button
                android:id="@+id/btnCerrarDetallePago"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/btn_secondary"
                android:text="@string/btn_cancelar"
                android:textColor="@color/soccer_green"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>