<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:elevation="24dp"
    app:cardCornerRadius="20dp"
    app:cardPreventCornerOverlap="true"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/white_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header con gradiente futbolero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Título del diálogo -->
            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚽ Registrar Gol"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="4dp"/>

            <!-- Subtítulo -->
            <TextView
                android:id="@+id/tvNombreJugador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Jugador"
                android:textSize="14sp"
                android:textColor="@color/white_translucent_70"/>

        </LinearLayout>

        <!-- Contenedor del formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/white_surface">

            <!-- Selector de tiempo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Periodo del Partido"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerPeriodoPartido"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card para el tiempo del evento -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiempo del Evento"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Contenedor de minutos y segundos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Input de Minutos -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxStrokeColor="@color/soccer_green"
                            app:hintTextColor="@color/soccer_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinutos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Min"
                                android:inputType="number"
                                android:maxLength="2"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:textColor="@color/text_primary"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Separador -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="'"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/soccer_green"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"/>

                        <!-- Input de Segundos -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxStrokeColor="@color/soccer_green"
                            app:hintTextColor="@color/soccer_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSegundos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Seg"
                                android:inputType="number"
                                android:maxLength="2"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:textColor="@color/text_primary"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Texto de ayuda -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Formato: MM' SS'' (ej. 15' 30'')"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Botón Cancelar -->
                <Button
                    android:id="@+id/btnCancelar"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_cancelar"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_secondary"
                    app:backgroundTint="@null"
                    android:textColor="@color/text_secondary"/>

                <!-- Botón Guardar -->
                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_guardar"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/btn_primary"
                    app:backgroundTint="@null"
                    android:textColor="@color/white"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>