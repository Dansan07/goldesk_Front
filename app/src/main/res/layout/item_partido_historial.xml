<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardViewItemPartidos"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Campeonato y Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/soccer_green"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_trophy"
                app:tint="@color/white"
                android:contentDescription="@string/campeonato"/>

            <TextView
                android:id="@+id/textViewChampionship"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Liga Profesional 2025"/>

            <TextView
                android:id="@+id/textViewStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@color/partido_finalizado"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="FINALIZADO"/>
        </LinearLayout>

        <!-- Cuerpo: Equipos y Resultado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Equipos y Marcador -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Equipo Local -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!--<ImageView
                        android:id="@+id/imageViewLocalTeam"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_team_placeholder"
                        android:contentDescription="@string/escudo_equipo_local"/>-->

                    <TextView
                        android:id="@+id/textViewLocalTeam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="River Plate"/>

                    <TextView
                        android:id="@+id/textViewLocalLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/local"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Marcador Central -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:id="@+id/layoutScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/textViewLocalScore"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/soccer_green"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            tools:text="2"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/text_secondary"
                            android:textSize="24sp"
                            android:paddingHorizontal="8dp"/>

                        <TextView
                            android:id="@+id/textViewVisitorScore"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/soccer_green"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            tools:text="1"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textViewVS"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VS"
                        android:textColor="@color/soccer_green"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Equipo Visitante -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!--<ImageView
                        android:id="@+id/imageViewVisitorTeam"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_team_placeholder"
                        android:contentDescription="@string/escudo_equipo_visitante"/>-->

                    <TextView
                        android:id="@+id/textViewVisitorTeam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Boca Juniors"/>

                    <TextView
                        android:id="@+id/textViewVisitorLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/visitante"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:background="@color/divider"/>

            <!-- Footer: Fecha, Hora y Ubicación -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Fecha y Hora -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/text_secondary"
                        android:contentDescription="@string/fecha"/>

                    <TextView
                        android:id="@+id/textViewDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="Sábado, 15 de Enero 2025"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/text_secondary"
                        android:contentDescription="@string/hora"/>

                    <TextView
                        android:id="@+id/textViewTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="16:00"/>
                </LinearLayout>

                <!-- Ubicación -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_stadium"
                        app:tint="@color/text_secondary"
                        android:contentDescription="@string/ubicacion"/>

                    <TextView
                        android:id="@+id/textViewLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Estadio Monumental Antonio Vespucio Liberti"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Botones de Acción (Opcionales) -->
            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btnEditMatch"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/editar"
                    android:textColor="@color/soccer_green"
                    android:textSize="13sp"/>

                <Button
                    android:id="@+id/btnDeleteMatch"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/eliminar"
                    android:textColor="@color/error"
                    android:textSize="13sp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>