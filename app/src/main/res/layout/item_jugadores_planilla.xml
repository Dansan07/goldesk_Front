<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:weightSum="3">

        <!-- Número del Jugador -->
        <TextView
            android:id="@+id/textViewPlayerNumber"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="7"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Información del Jugador -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewPlayerName"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:text="Cristiano Ronaldo"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Estadísticas del Jugador -->
        <LinearLayout
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Goles -->
            <LinearLayout
                android:id="@+id/layoutGoals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_soccer_ball_small"
                    app:tint="@color/soccer_green"/>

                <TextView
                    android:id="@+id/textViewGoals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/soccer_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="16dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Tarjeta Amarilla -->
            <LinearLayout
                android:id="@+id/layoutYellowCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_card"
                    app:tint="#FFC107"/>

                <TextView
                    android:id="@+id/textViewYellowCards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="16dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!--Tarjeta Azul-->
            <LinearLayout
                android:id="@+id/layoutBlueCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_card"
                    app:tint="#1861F4"/>

                <TextView
                    android:id="@+id/textViewBlueCards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="16dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Tarjeta Roja -->
            <LinearLayout
                android:id="@+id/layoutRedCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_card"
                    app:tint="#F44336"/>

                <TextView
                    android:id="@+id/textViewRedCards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="16dp"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Menú de opciones -->
        <!--<ImageButton
            android:id="@+id/btnPlayerMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="@string/opciones_jugador"
            app:tint="@color/text_secondary"/>-->

    </LinearLayout>

</androidx.cardview.widget.CardView>