<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_goleador"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/white_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:paddingVertical="10dp"
        android:weightSum="3"
        android:gravity="center">

        <!-- Posición (rank) -->
        <TextView
            android:id="@+id/txt_posicionGoleador"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/bg_rank" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="2">

            <!-- Nombre del jugador -->
            <TextView
                android:id="@+id/txt_nombreGoleador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="un Nombre Jugador igual de largo"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/dialog_text_primary"
                android:layout_marginStart="12dp" />

            <!-- Subtexto debajo del nombre -->
            <TextView
                android:id="@+id/txt_partidosGoleador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 partidos jugados"
                android:textSize="11sp"
                android:textColor="@color/dialog_text_secondary"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Nombre del equipo -->
        <TextView
            android:id="@+id/txt_equipoGoleador"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre equipo"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_equipo_tag"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_marginHorizontal="12dp"
            android:textAlignment="center"/>

        <!-- Goles (badge) -->
        <FrameLayout
            android:id="@+id/frame_goles"
            android:layout_width="40dp"
            android:layout_height="40dp">

            <TextView
                android:id="@+id/txt_golesGoleador"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:text="7"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/soccer_green"
                android:gravity="center"
                android:background="@drawable/bg_goles_badge"
                android:layout_gravity="center"/>
        </FrameLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>