<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================
         ESTE ARCHIVO VA EN: res/values-night/colors.xml
         NO en res/values/colors.xml — son dos archivos DIFERENTES
         en dos carpetas DIFERENTES. Android elige uno u otro según
         el modo del sistema. Si los mezclas en una sola carpeta,
         el modo oscuro deja de ser "modo oscuro" y se vuelve fijo.
         ============================================================ -->

    <color name="white_surface">#FF1E1E1E</color>
    <!-- Blanco translúcido (70% opacidad): mismo valor que en modo
         claro a propósito. Solo se usa sobre fondos de color fijo
         (headers verdes, gradientes) que tampoco cambian con el
         modo, así que no necesita una variante oscura distinta. -->
    <color name="white_translucent_70">#B3FFFFFF</color>

    <!-- Highlight verde sutil (modo oscuro): NO usamos un verde
         pálido/claro aquí, ya que eso se vería como un parche claro
         fuera de lugar sobre fondo oscuro. En su lugar, un gris
         oscuro con un tinte verde leve, apenas más claro que
         white_surface, para dar la misma sensación de seccion
         destacada sin romper el contraste general de la pantalla. -->
    <color name="highlight_verde_sutil">#1B2E1F</color>
    <color name="highlight_verde_sutil_text_primary">#8FD19E</color>
    <color name="highlight_verde_sutil_text_secondary">#6FA87D</color>

