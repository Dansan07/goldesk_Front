<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.GoldeskApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.GoldeskApp" parent="Base.Theme.GoldeskApp" />

    <style name="Widget.Goldesk.RoleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/bg_role_button</item>
        <item name="strokeColor">@color/soccer_green</item>
        <!--<item name="android:textColor">@color/role_button_background</item>-->
        <!--<item name="iconTint">@color/role_button_content_selector</item>-->
        <item name="rippleColor">@color/white</item>
    </style>

    <!-- styles.xml -->

    <!-- Tema principal del diálogo -->
    <style name="CustomDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- Fondo del diálogo -->
        <item name="materialAlertDialogBodyTextStyle">@style/MaterialAlertDialog.Body.WithBorder</item>
        <item name="backgroundInsetStart">16dp</item>
        <item name="backgroundInsetEnd">16dp</item>
        <item name="backgroundInsetTop">48dp</item>
        <item name="backgroundInsetBottom">48dp</item>

        <!-- Animación -->
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>

        <!-- Elevación y sombra -->
        <item name="android:windowElevation">24dp</item>

        <!-- Forma redondeada -->
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Dialog.Rounded</item>

        <!-- Colores -->
        <item name="colorSurface">@color/white</item>
        <item name="colorPrimary">@color/soccer_green</item>
        <item name="colorSecondary">@color/soccer_green</item>
        <item name="colorOnSurface">@color/dialog_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/dialog_text_secondary</item>

        <!-- Tipografía -->
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Dialog.Title</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Dialog.Message</item>

        <!-- Botones -->
        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Dialog.Button.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/Dialog.Button.Neutral</item>

        <!-- Estilo de divider -->
        <item name="dividerColor">@color/dialog_divider</item>
    </style>
    <style name="CustomMaterialDialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textAppearance">@style/TextAppearance.Dialog.Message</item>
        <item name="android:textColor">@color/dialog_text_secondary</item>
    </style>

    <!-- Forma redondeada del diálogo -->
    <style name="ShapeAppearance.Dialog.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Animaciones del diálogo -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <!-- Tipografía del título -->
    <style name="TextAppearance.Dialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dialog_text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Tipografía del mensaje -->
    <style name="TextAppearance.Dialog.Message" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/dialog_text_secondary</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <!-- Botón positivo (Confirmar, Aceptar, Guardar) -->
    <style name="Dialog.Button.Positive" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="backgroundTint">@color/soccer_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/button_ripple_positive</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Botón negativo (Cancelar, No) -->
    <style name="Dialog.Button.Negative" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="strokeColor">@color/dialog_button_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/dialog_text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">@color/button_ripple_negative</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Botón neutral (opcional) -->
    <style name="Dialog.Button.Neutral" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dialog_text_secondary</item>
        <item name="rippleColor">@color/button_ripple_neutral</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Variante con fondo oscuro -->
    <style name="CustomDialogTheme.Dark" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background_dark</item>
        <item name="backgroundInsetStart">16dp</item>
        <item name="backgroundInsetEnd">16dp</item>
        <item name="backgroundInsetTop">48dp</item>
        <item name="backgroundInsetBottom">48dp</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <item name="android:windowElevation">24dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Dialog.Rounded</item>

        <item name="colorSurface">@color/dialog_dark_background</item>
        <item name="colorPrimary">@color/soccer_green</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/dialog_dark_text_secondary</item>

        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Dialog.Button.Negative.Dark</item>
    </style>

    <style name="Dialog.Button.Negative.Dark" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="strokeColor">@color/dialog_dark_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">@color/button_ripple_negative_dark</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- ========================================== -->
    <!-- ESTILOS ADICIONALES CON BORDES PERSONALIZADOS -->
    <!-- ========================================== -->

    <!-- Tema con borde azul (para información) -->
    <style name="CustomDialogTheme.Info" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_blue</item>
        <item name="colorPrimary">@color/dialog_info_blue</item>
        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Blue</item>
    </style>

    <style name="Dialog.Button.Blue" parent="Dialog.Button.Positive">
        <item name="backgroundTint">@color/dialog_info_blue</item>
    </style>

    <!-- Tema con borde amarillo (para advertencias) -->
    <style name="CustomDialogTheme.Warning" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_warning</item>
        <item name="colorPrimary">@color/dialog_warning_yellow</item>
        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Warning</item>
    </style>

    <style name="Dialog.Button.Warning" parent="Dialog.Button.Positive">
        <item name="backgroundTint">@color/dialog_warning_yellow</item>
    </style>

    <!-- Variante con acento rojo para acciones destructivas -->
    <style name="CustomDialogTheme.Destructive" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_destructive</item>
        <item name="colorPrimary">@color/error_red</item>
        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Destructive</item>
    </style>

    <style name="Dialog.Button.Destructive" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="backgroundTint">@color/error_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/button_ripple_destructive</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="MaterialAlertDialog.Body.WithBorder" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textAppearance">@style/TextAppearance.Dialog.Message</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Tema con borde grueso
    <style name="CustomDialogTheme.ThickBorder" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_thick</item>
    </style>

    &lt;!&ndash; Tema con borde degradado &ndash;&gt;
    <style name="CustomDialogTheme.Gradient" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_gradient</item>
    </style>

    &lt;!&ndash; Tema con doble borde &ndash;&gt;
    <style name="CustomDialogTheme.DoubleBorder" parent="CustomDialogTheme">
        <item name="android:windowBackground">@drawable/dialog_background_double_border</item>
    </style>-->

</resources>